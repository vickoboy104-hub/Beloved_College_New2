APP_NAME="Beloved College"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://belovedcollege.test
APP_COMMIT_SHA=

PUBLIC_HOST=belovedcollege.test
WEB_PORTAL_HOST=web.belovedcollege.test
APP_PORTAL_HOST=app.belovedcollege.test
ADDITIONAL_TRUSTED_HOSTS=
DEFAULT_THEME=classic
ALLOW_USER_THEME_SELECTION=true
LEGACY_COMPATIBILITY=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=beloved_college
# DB_USERNAME=root
# DB_PASSWORD=

# Read-only staging copy of the previous system for reconciliation.
LEGACY_DB_CONNECTION=legacy
LEGACY_DB_DRIVER=mysql
LEGACY_DB_HOST=127.0.0.1
LEGACY_DB_PORT=3306
LEGACY_DB_DATABASE=
LEGACY_DB_USERNAME=
LEGACY_DB_PASSWORD=
LEGACY_DB_SOCKET=
LEGACY_DB_CHARSET=utf8mb4
LEGACY_DB_COLLATION=utf8mb4_unicode_ci
# Isolated copies of the legacy private and public upload roots.
LEGACY_PRIVATE_FILES_ROOT=
LEGACY_PUBLIC_FILES_ROOT=
MIGRATION_TARGET_CONNECTION=${DB_CONNECTION}
MIGRATION_REPORT_DISK=local
MIGRATION_REPORT_DIRECTORY=migration-reports
MIGRATION_READINESS_ALLOW_PRODUCTION=false
# Optional expected SHA-256 fingerprint of the original APP_KEY, never the key itself.
MIGRATION_EXPECTED_APP_KEY_FINGERPRINT=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# For shared production authentication across subdomains, use:
# SESSION_DOMAIN=.belovedcollege.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
